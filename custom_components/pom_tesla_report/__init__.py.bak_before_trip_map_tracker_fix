            lines.append("Kapı/bina no: OpenStreetMap verisinde görünmüyor.")
    else:
        lines.append("Adres: Açık adres şu anda alınamadı.")

    lines.extend([
        "",
        "Haritada aç:",
        maps_link,
    ])

    return "\n".join(lines)


