        entries = hass.config_entries.async_entries(DOMAIN)
        if not entries:
            return
        entry_obj = entries[0]
        cancel_live_trip_test_task(hass, entry_obj.entry_id)
        state = get_live_trip_state(hass, entry_obj.entry_id)
        state.clear()
        state.update({
            "status": "idle",
            "active": False,
            "test_mode": False,
            "test_progress": 0.0,
            "last_update": datetime.now().strftime("%d.%m.%Y %H:%M:%S"),
